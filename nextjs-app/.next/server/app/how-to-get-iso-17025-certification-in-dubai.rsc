1f:["$","p","33",{"className":"mb-6 text-justify leading-8","children":"ISO Certification in UAE is a most preferred Certification Standard by organizations in UAE from all sectors. Wizms provides ISO Certificate in UAE for all major standards such as ISO 9001:2015, ISO 14001:2015, ISO 27001:2015, ISO 17025:2017, ISO 45001:2018 and more."}]
20:["$","p","34",{"className":"mb-6 text-justify leading-8","children":"Wizms is the best ISO consultant in UAE and provides ISO consulting services in Dubai, Abu Dhabi, Sharjah, Ras al-Khaimah, Ajman, Al Ain and Fujairah. Wizms ISO consultant in Dubai offers top-class ISO consultancy services including ISO Consulting, ISO Certification, ISO Training in UAE, Gap analysis, Documentation, Implementation, and ISO certification audits in UAE."}]
