10:["$","p","10",{"className":"mb-6 text-justify leading-8","children":"General requirements for ISO 22000 certification in Dubai"}]
11:["$","p","11",{"className":"mb-6 text-justify leading-8","children":"Overall Food Safety Policy developed and guided by the top management authorities"}]
12:["$","p","12",{"className":"mb-6 text-justify leading-8","children":"Setting the objectives and goals for your organization that should comply with this policy"}]
13:["$","p","13",{"className":"mb-6 text-justify leading-8","children":"Flawless planning and designing of the process and documenting that system"}]
14:["$","p","14",{"className":"mb-6 text-justify leading-8","children":"Regular assessment of the performance of the system"}]
15:["$","p","15",{"className":"mb-6 text-justify leading-8","children":"Assigning qualified delegates to manage the Food safety system"}]
16:["$","p","16",{"className":"mb-6 text-justify leading-8","children":"Designing a contingency plan"}]
17:["$","p","17",{"className":"mb-6 text-justify leading-8","children":"Regular management review meetings"}]
18:["$","p","18",{"className":"mb-6 text-justify leading-8","children":"Lucid communication from top to bottom level which includes customers, employees, suppliers and others"}]
19:["$","p","19",{"className":"mb-6 text-justify leading-8","children":"Abiding by HACCP principles"}]
1a:["$","p","20",{"className":"mb-6 text-justify leading-8","children":"Catering sufficient resources for the effective and efficient operation of FSMS"}]
1b:["$","p","21",{"className":"mb-6 text-justify leading-8","children":"Traceability system for easy product identification"}]
1c:["$","p","22",{"className":"mb-6 text-justify leading-8","children":"Assessing best performing and non-performing products"}]
1d:["$","p","23",{"className":"mb-6 text-justify leading-8","children":"Internal auditing for handling the withdrawal of the product"}]
1e:["$","p","24",{"className":"mb-6 text-justify leading-8","children":"Devise to measure, monitor and control the food safety system"}]
1f:["$","p","25",{"className":"mb-6 text-justify leading-8","children":"Consistency practice"}]
