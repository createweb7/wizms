17:["$","div",null,{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-bold text-gray-900 mb-4","children":"ISO 22301 Certification in Dubai, UAE"}],["$","p",null,{"className":"text-gray-700 mb-4","children":"To get BCMS ISO 22301 certification in Dubai, UAE choose the best ISO 22301 certification consultant in Dubai, UAE. Wizms is the best ISO 22301 certification consultancy in Dubai with an impeccable experience of helping the organization to get ISO 22301 certification quickly and easily."}],["$","p",null,{"className":"text-gray-700","children":"Our ISO certification consultancy will help you get through an easy procedure that allows your firm to obtain ISO certification within 4-6 weeks. Our team is specialized in Business Continuity Management Systems and gives a detailed study of your organizational activities along with documentation of the procedure under ISO 22301 standard requirements. Our systematic approach ensures that you obtain ISO 22301 certification on the first attempt."}]]}]
