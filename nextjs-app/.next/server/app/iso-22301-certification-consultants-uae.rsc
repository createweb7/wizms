8:["$","div",null,{"className":"min-h-screen bg-gray-50","children":[["$","div",null,{"className":"border-t border-gray-200","children":["$","div",null,{"className":"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4","children":["$","nav",null,{"className":"flex items-center gap-2 text-sm text-gray-600","children":[["$","$Lf",null,{"href":"/","className":"hover:text-gray-900 hover:underline","children":"Home"}],["$","span",null,{"className":"text-gray-400","children":"/"}],["$","span",null,{"className":"text-gray-900 font-semibold","children":"ISO 22301 Certification"}]]}]}]}],["$","div",null,{"className":"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16","children":["$","div",null,{"className":"grid grid-cols-1 lg:grid-cols-3 gap-8","children":[["$","div",null,{"className":"lg:col-span-2","children":["$","div",null,{"className":"bg-white rounded-lg shadow-sm p-8","children":[["$","h1",null,{"className":"text-4xl font-bold text-gray-900 mb-4","children":"BCMS ISO 22301 Certification Consultants in Dubai, UAE"}],["$","p",null,{"className":"text-lg text-gray-700 leading-relaxed mb-4","children":"Wizms offers Business Continuity Management System (BCMS) ISO 22301 Certification in UAE, Dubai that is valid for 3 years. BCM certification in UAE describes how to manage the business continuity in a company by establishing framework, implement and plan. An organization can get ISO 22301 standard from certified ISO certification bodies and hence they can prove its compliance to their customers, partners, clients."}],["$","p",null,{"className":"text-gray-700 mb-4","children":"Business Continuity Management System intends to protect organizations from a wide range of dangers related to downtime, which can happen due to unexpected disasters or disruptions. Interruptions to the business can result in data risk breakdown, profit loss, and unsuccessful to deliver regular client services according to the service level agreements."}],["$","p",null,{"className":"text-gray-700 mb-6","children":"ISO standard is the best standard for your association if you have to exhibit to partners that your organization can quickly overcome operational interruption to provide continued and effective services. ISO 22301 BCMS certification will direct an organization on how best to plan for such eventualities."}],["$","div",null,{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-bold text-gray-900 mb-4","children":"Importance of BCMS ISO 22301 Certification in Dubai, UAE for an organization"}],["$","p",null,{"className":"text-gray-700 mb-4","children":"BCM ISO 22301 certification provides an organization with the power of giving a premium level of services to their investors regardless of the conditions. ISO 22301 BCMS recognizes the capability to safeguard data backups, reduce major losses, and increase the recovery time of critical faculty."}],["$","p",null,{"className":"text-gray-700","children":"By getting ISO 22301 business continuity management system, an organization can upgrade their skills and knowledge; they will be able to advise their employees on best practices of ISO business continuity."}]]}],["$","div",null,{"className":"mb-10 bg-teal-50 border-l-4 border-teal-500 p-6 rounded","children":[["$","h2",null,{"className":"text-2xl font-bold text-gray-900 mb-4","children":"How ISO 22301 Works"}],["$","p",null,{"className":"text-gray-700 mb-4","children":"ISO 22301 focuses on the continuity of the business after the delivery of products and services. The working process of ISO 22301 is:"}],["$","ul",null,{"className":"space-y-2 text-gray-700","children":[["$","li",null,{"className":"flex gap-3 items-start","children":[["$","svg",null,{"stroke":"currentColor","fill":"currentColor","strokeWidth":"0","viewBox":"0 0 24 24","className":"text-teal-600 shrink-0 mt-1","children":["$undefined",["$L10","$L11"]],"style":{"color":"$undefined"},"height":"1em","width":"1em","xmlns":"http://www.w3.org/2000/svg"}],"$L12"]}],"$L13","$L14","$L15"]}],"$L16"]}],"$L17","$L18","$L19","$L1a"]}]}],"$L1b"]}]}]]}]
